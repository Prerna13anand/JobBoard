# Copy this file to .env and fill in the credentials you have.
# .env is git-ignored and must never be committed.
# These are used by Phase 2 (API-key-based) job sources - none of the
# Phase 1 sources (Arbeitnow, Himalayas, RemoteOK, Jobicy, The Muse,
# Bundesagentur fur Arbeit) require any of these.

# USAJOBS - https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Adzuna - https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble - https://jooble.org/api/about
JOOBLE_API_KEY=

# Reed - https://www.reed.co.uk/developers
REED_API_KEY=

# SerpApi - https://serpapi.com/
SERPAPI_API_KEY=

# TheirStack - https://theirstack.com/
THEIRSTACK_API_KEY=

# OpenWebNinja - https://www.openwebninja.com/
OPENWEBNINJA_API_KEY=

# CareerJet - https://www.careerjet.com/partners/api/
CAREERJET_API_KEY=

# CareerOneStop / NLx - https://www.careeronestop.org/Developers/WebAPI/web-api.aspx
CAREERONESTOP_USER_ID=
CAREERONESTOP_API_TOKEN=
