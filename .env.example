# Copy this file to .env and fill in the credentials you have.
# .env is git-ignored and must never be committed.
# These are used by Phase 2 (API-key-based) job sources - none of the
# Phase 1 sources (Arbeitnow, Himalayas, RemoteOK, Jobicy, The Muse,
# Bundesagentur fur Arbeit) require any of these.

# USAJOBS - https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Adzuna - https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble - https://jooble.org/api/about
JOOBLE_API_KEY=

# Reed - https://www.reed.co.uk/developers
REED_API_KEY=

# SerpApi - https://serpapi.com/
SERPAPI_API_KEY=

# TheirStack - https://theirstack.com/
THEIRSTACK_API_KEY=

# OpenWebNinja - https://www.openwebninja.com/
OPENWEBNINJA_API_KEY=

# CareerJet - https://www.careerjet.com/partners/api/
CAREERJET_API_KEY=

# CareerOneStop / NLx - https://www.careeronestop.org/Developers/WebAPI/web-api.aspx
CAREERONESTOP_USER_ID=
CAREERONESTOP_API_TOKEN=

# Findwork.dev - https://findwork.dev/developers/
FINDWORK_API_KEY=

# France Travail - https://francetravail.io/produits-partages/catalogue/offres-emploi
# Free account required at francetravail.io; create an "application" there to
# get a client ID/secret (OAuth2 client_credentials), then subscribe that
# application to the "Offres d'emploi" API.
FRANCETRAVAIL_CLIENT_ID=
FRANCETRAVAIL_CLIENT_SECRET=

# Trade Me Jobs - https://developer.trademe.co.nz/
# Free Trade Me membership required; register an application from
# My Trade Me > My Applications > Developer options to get a Consumer
# Key/Secret. Production registration is subject to Trade Me's use-case
# review (not guaranteed instant) - the sandbox environment is
# auto-approved if you want to test against tmsandbox.co.nz first.
TRADEME_CONSUMER_KEY=
TRADEME_CONSUMER_SECRET=

# Fantastic.jobs - https://developer.fantastic.jobs/
# Free account at developer.fantastic.jobs; a 7-day free trial (no credit
# card required) issues an API key immediately from the subscriptions
# page. Paid tier beyond the trial is metered (~$1 per 1,000 jobs).
FANTASTICJOBS_API_KEY=

# PostgreSQL (see MIGRATION.md) - used by database.py to store every
# fetched job alongside jobs.json. Not required to run jobs.py at all: if
# PostgreSQL isn't reachable, the database save is skipped and jobs.json is
# still written normally.
#
# Either set DATABASE_URL (takes priority if present)...
DATABASE_URL=
# ...or set these individually (defaults shown are what's used if unset):
PGHOST=localhost
PGPORT=5432
PGDATABASE=jobboard
PGUSER=postgres
PGPASSWORD=
